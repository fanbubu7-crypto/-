# API 认证令牌（可选，提高速率限制）

# GitHub API Token (从 https://github.com/settings/tokens 获取)
GITHUB_TOKEN=

# Gitee API Token (从 https://gitee.com/profile/personal_access_tokens 获取)
GITEE_TOKEN=

# API 超时设置 (秒)
GITHUB_API_TIMEOUT=10
GITEE_API_TIMEOUT=10

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
